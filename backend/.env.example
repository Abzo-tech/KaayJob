# KaayJob Backend Environment Variables
# Copiez ce fichier en .env et configurez les valeurs

# Server
PORT=3001
NODE_ENV=development

# Database PostgreSQL
DB_HOST=127.0.0.1
DB_PORT=5432
DB_NAME=kaayjob
DB_USER=postgres
DB_PASSWORD=postgres

DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:5432/kaayjob

# Production Database URL (Neon Serverless)
# ⚠️ SÉCURITÉ: NE JAMAIS STOCKER L'URL RÉELLE ICI
# Définir dans les variables d'environnement du système de déploiement
# DATABASE_URL="postgresql://username:password@host:port/database?sslmode=verify-full"

# Frontend URL (pour CORS)
FRONTEND_URL=http://localhost:3000

# JWT Secret (changez en production!)
JWT_SECRET=kaayjob-super-secret-key-change-in-production-2024

# JWT Expiration
JWT_EXPIRES_IN=7d
